# ── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173

# ── Database (PostgreSQL) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerxe
DB_USER=ecommerxe_user
DB_PASSWORD=your_strong_db_password_here
DB_SSL=false

# ── Redis ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_TTL=1800

# ── JWT (RS256 — generate keys with: openssl genrsa -out private.pem 4096)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_REFRESH_SECRET=your_separate_refresh_hmac_secret_here

# ── Google OAuth 2.0 ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# ── Cloudflare R2 / S3-compatible ────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=ecommerxe-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
CDN_URL=https://cdn.yourdomain.com

# ── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
SMTP_FROM=no-reply@ecommerxe.com

# ── Sentry ───────────────────────────────────────────────────────
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project

# ── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ── Encryption ───────────────────────────────────────────────────
ENCRYPTION_KEY=32_char_hex_key_for_aes256_here_x

# ── Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
